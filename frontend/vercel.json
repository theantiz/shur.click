{
  "framework": "vite",
  "redirects": [
    {
      "source": "/:code((?!api$|auth$|user$|login$|signup$|dashboard$|forgot-password$|reset-password$|track$|favicon.ico$|favicon-16x16.png$|favicon-32x32.png$|apple-touch-icon.png$|android-chrome-192x192.png$|android-chrome-512x512.png$|robots.txt$|sitemap.xml$)[A-Za-z0-9_-]{3,20})",
      "destination": "https://api.shur.click/:code",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.shur.click/api/:path*"
    },
    {
      "source": "/:code((?!api$|auth$|user$|login$|signup$|dashboard$|forgot-password$|reset-password$|track$|favicon.ico$)[A-Za-z0-9_-]{3,20})",
      "destination": "https://api.shur.click/:code"
    },
    {
      "source": "/r/:code*",
      "destination": "https://api.shur.click/:code*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
